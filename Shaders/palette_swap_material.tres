[gd_resource type="ShaderMaterial" format=3 uid="uid://dq56kvtjp86e0"]

[sub_resource type="VisualShaderNodeExpression" id="VisualShaderNodeExpression_ygbrg"]
size = Vector2(520, 560)
expression = "vec2 new_uv = vec2(0.0, 0.0);
float best_dist = 999.0;

for (int i = 0; i < colors_count; i++) {
    float u = (float(i) + 0.5) / float(colors_count);  // fixed parentheses
    vec2 uv = vec2(u, 0.5);
    vec4 original_palette_color = texture(original_palette, uv);
    float dist = distance(color.rgb, original_palette_color.rgb);
    
    if (dist < best_dist) {  // nearest match instead of exact equality
        best_dist = dist;
        new_uv = uv;
    }
}

new_color = texture(new_palette, new_uv);"

